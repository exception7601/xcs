{
  "name": "xcs",
  "version": "1.0.0",
  "description": "Simple CLI for one-key xcstrings updates.",
  "type": "module",
  "private": true,
  "bin": {
    "xcs": "./src/cli.js"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "check": "npm run lint && npm run format:check && npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.4"
  }
}
